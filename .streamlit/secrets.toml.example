# ==============================================================================
# Streamlit Secrets Template for TripAI Platform
# ==============================================================================
# Copy this file to `.streamlit/secrets.toml` and fill in your API keys.
# DO NOT commit your actual secrets.toml file to git.
# ==============================================================================

# Google Maps Platform Distance Matrix API Key (Optional)
# If omitted, TripAI will fall back to its internal 3-tier local SQLite/offline coordinate database.
GOOGLE_MAPS_API_KEY = "your_google_maps_api_key_here"

# Open-Meteo API is keyless and does not require credentials.
# Gemini API Key (If Gemini integration is enabled)
GEMINI_API_KEY = "your_gemini_api_key_here"
